{
  "name": "@oidc-exchange/node",
  "version": "0.1.0",
  "description": "Node.js bindings for oidc-exchange - OIDC token exchange service",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/antstanley/oidc-exchange.git",
    "directory": "bindings/nodejs"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --release",
    "test": "vitest run",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2",
    "oxfmt": "^0",
    "oxlint": "^0",
    "vitest": "^3"
  },
  "napi": {
    "name": "oidc-exchange",
    "triples": {
      "defaults": false,
      "additional": [
        "x86_64-unknown-linux-gnu",
        "aarch64-unknown-linux-gnu",
        "x86_64-pc-windows-msvc",
        "aarch64-apple-darwin"
      ]
    }
  },
  "engines": {
    "node": ">= 22"
  },
  "packageManager": "pnpm@10.11.0"
}
